{
  "cli": {
    "version": ">= 13.2.0",
    "appVersionSource": "local"
  },
  "build": {
    "driver-apk": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "env": {
        "APP_VARIANT": "driver",
        "EAS_PROJECT_ID_DRIVER": "01426c18-feb5-44f2-94f1-dab900d8bc85",
        "EAS_PROJECT_ID_PASSENGER": "23cab91b-82a5-4d92-9709-017279a2539d"
      }
    },
    "passenger-apk": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "env": {
        "APP_VARIANT": "passenger",
        "EAS_PROJECT_ID_DRIVER": "01426c18-feb5-44f2-94f1-dab900d8bc85",
        "EAS_PROJECT_ID_PASSENGER": "23cab91b-82a5-4d92-9709-017279a2539d"
      }
    }
  }
}
