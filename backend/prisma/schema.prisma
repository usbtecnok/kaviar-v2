  drivers_approved      Int       @default(0)
  first_contact_at      DateTime  @default(now())
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  @@index([status])
  @@index([city])
}

// ─── Parceiros Territoriais KAVIAR ──────────────────────────────────────────
model territorial_partners {
  id                  String   @id @default(uuid())
  name                String
  partner_type        String   @default("association") // association | condominium | business | community_leader | institution | other
  address             String?
  responsible_name    String
  responsible_role    String   @default("presidente")
  responsible_phone   String?
  responsible_email   String?
  commission_percent  Decimal  @default(5) @db.Decimal(5, 2)
  monthly_fee_cents   Int?
  billing_due_day     Int?     // dia do mês para vencimento (1-28)
  billing_status      String   @default("current") // current | pending | overdue | blocked | canceled
  last_payment_at     DateTime?
  referral_code       String?  @unique
  public_token        String?  @unique
  plan                String   @default("basic") // basic | management
  logo_url            String?
  status              String   @default("active") // active | paused | inactive
  notes               String?
  contract_status     String   @default("pending") // pending | signed | not_required
  contract_url        String?
  contract_signed_at  DateTime?
  contract_notes      String?
  territory_id        String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  drivers             drivers[]
  commissions         partner_commissions[]
  payments            partner_payments[]
  link_requests       partner_link_requests[]
  members             partner_members[]
  transactions        partner_transactions[]
  users               partner_users[]
  member_payments     partner_member_payments[]
  territory           operational_territories? @relation(fields: [territory_id], references: [id])

  @@index([status])
  @@index([partner_type])
  @@index([billing_status])
  @@index([territory_id], map: "idx_territorial_partners_territory")
}

model partner_commissions {
  id                 String   @id @default(uuid())
  partner_id         String
  ride_id            String
  driver_id          String
  ride_final_price   Decimal  @db.Decimal(8, 2)
  commission_percent Decimal  @db.Decimal(5, 2)
  commission_amount  Decimal  @db.Decimal(8, 2)
  status             String   @default("pending") // pending | paid | canceled
  paid_at            DateTime?
  paid_by            String?
  created_at         DateTime @default(now())

  partner            territorial_partners @relation(fields: [partner_id], references: [id])

  @@unique([ride_id, partner_id])
  @@index([partner_id, status])
  @@index([driver_id])
}

model partner_payments {
  id              String   @id @default(uuid())
  partner_id      String
  amount_cents    Int
  reference_month String?  // "2026-05" formato YYYY-MM
  paid_at         DateTime
  receipt_url     String?
  notes           String?
  registered_by   String   // admin_id
  created_at      DateTime @default(now())

  partner         territorial_partners @relation(fields: [partner_id], references: [id])

  @@index([partner_id, paid_at(sort: Desc)])
}

model partner_link_requests {
  id          String   @id @default(uuid())
  partner_id  String
  driver_id   String
  status      String   @default("pending") // pending | approved | rejected
  source      String   @default("referral_code") // referral_code | admin_manual | partner_invite
  reviewed_at DateTime?
  reviewed_by String?
  created_at  DateTime @default(now())

  partner     territorial_partners @relation(fields: [partner_id], references: [id])

  @@unique([partner_id, driver_id])
  @@index([partner_id, status])
  @@index([status])
}

model partner_members {
  id          String   @id @default(uuid())
  partner_id  String
  name        String
  unit        String?  // apt 101, casa 3, etc
  status      String   @default("active") // active | inactive
  created_at  DateTime @default(now())

  partner     territorial_partners @relation(fields: [partner_id], references: [id])
  payments    partner_member_payments[]

  @@index([partner_id, status])
}

model partner_member_payments {
  id              String    @id @default(uuid())
  partner_id      String
  member_id       String
  reference_month String
  amount_cents    Int
  payment_method  String    @default("pix") // pix | dinheiro | transferencia | cartao | outro
  paid_at         DateTime  @default(now())
  receipt_code    String    @unique
  notes           String?
  registered_by   String
  whatsapp_sent_at DateTime?
  created_at      DateTime  @default(now())

  partner  territorial_partners @relation(fields: [partner_id], references: [id])
  member   partner_members      @relation(fields: [member_id], references: [id])

  @@index([partner_id, reference_month])
  @@index([member_id])
}

model partner_transactions {
  id              String   @id @default(uuid())
  partner_id      String
  type            String   // income | expense
  amount_cents    Int
  description     String
  category        String   @default("outro") // mensalidade | manutencao | limpeza | evento | outro
  reference_month String?  // 2026-05
  member_id       String?
  created_at      DateTime @default(now())

  partner         territorial_partners @relation(fields: [partner_id], references: [id])

  @@index([partner_id, reference_month])
  @@index([partner_id, type])
}

model partner_users {
  id            String   @id @default(uuid())
  partner_id    String
  name          String
  email         String   @unique
  password_hash String
  is_active     Boolean  @default(true)
  last_login_at DateTime?
  created_at    DateTime @default(now())

  partner         territorial_partners      @relation(fields: [partner_id], references: [id])
  password_resets partner_password_resets[]

  @@index([partner_id])
}

model partner_password_resets {
  id              String    @id @default(uuid())
  partner_user_id String
  code_hash       String
  expires_at      DateTime
  used_at         DateTime?
  created_at      DateTime  @default(now())
  request_ip      String?
  user_agent      String?

  user partner_users @relation(fields: [partner_user_id], references: [id], onDelete: Cascade)

  @@index([partner_user_id])
  @@index([expires_at])
}

model private_ride_requests {
  id                  String   @id @default(uuid())
  name                String
  phone               String
  service_type        String   @default("outro") // consulta | mercado | escola | aeroporto | evento | idoso | compromisso | outro
  scheduled_date      String   // 2026-05-15
  scheduled_time      String   // 14:00
  origin              String
  destination         String
  round_trip          Boolean  @default(false)
  wait_at_destination Boolean  @default(false)
  notes               String?
  status              String   @default("new") // new | analyzing | confirmed | completed | canceled
  assigned_driver     String?
  admin_notes         String?
  partner_id          String?
  created_at          DateTime @default(now())
  updated_at          DateTime @default(now()) @updatedAt

  @@index([status])
  @@index([scheduled_date])
  @@index([partner_id])
}

model local_businesses {
  id          String   @id @default(uuid())
  name        String
  category    String   @default("outro")
  description String?
  whatsapp    String?
  address     String?
  logo_url    String?
  region_slug String
  partner_id  String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now()) @updatedAt

  @@index([region_slug, is_active])
}

// ─── Territórios Operacionais (Multioperação) ────────────────────────────────
model operational_territories {
  id         String   @id @default(uuid())
  name       String
  level      String   // "country" | "state" | "city" | "region" | "operation"
  status     String   @default("active") // "planning" | "preparation" | "active" | "inactive"
  parent_id  String?
  uf         String?  // sigla do estado: RJ, SP, MG
  city_name  String?
  center_lat Decimal? @db.Decimal(10, 8)
  center_lng Decimal? @db.Decimal(11, 8)
  notes      String?
  regulatory_status     String   @default("not_evaluated")
  regulatory_notes      String?
  regulatory_checked_at DateTime?
  regulatory_checked_by String?
  is_active  Boolean  @default(true)
  moto_express_enabled Boolean @default(false)
  moto_passenger_enabled Boolean @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  parent   operational_territories?  @relation("TerritoryHierarchy", fields: [parent_id], references: [id])
  children operational_territories[] @relation("TerritoryHierarchy")

  neighborhoods        neighborhoods[]
  territorial_partners territorial_partners[]
  admin_access         admin_territory_access[]
  finance_rules        territory_finance_rules[]
  operator_profiles    operator_profiles[]
  payouts              territory_payouts[]
  manager_assignments  territory_manager_assignments[]
  shadow_results       wallet_shadow_results[]

  @@unique([name, level, parent_id])
  @@index([level])
  @@index([status])
  @@index([parent_id])
}

model admin_territory_access {
  id           String   @id @default(uuid())
  admin_id     String
  territory_id String
  access_level String   @default("full") // "full" | "read_only"
  created_at   DateTime @default(now())

  admin     admins                  @relation(fields: [admin_id], references: [id], onDelete: Cascade)
  territory operational_territories @relation(fields: [territory_id], references: [id], onDelete: Cascade)

  @@unique([admin_id, territory_id])
  @@index([admin_id])
  @@index([territory_id])
}

// ─── Regras Financeiras Territoriais (Simulação) ─────────────────────────────
model territory_finance_rules {
  id                         String   @id @default(uuid())
  territory_id               String
  matrix_share_percent       Decimal  @default(60) @db.Decimal(5, 2)
  regional_share_percent     Decimal  @default(40) @db.Decimal(5, 2)
  partner_commission_percent Decimal  @default(5) @db.Decimal(5, 2)
  min_monthly_fee_cents      Int?
  revenue_threshold_cents    Int?
  description                String?
  is_active                  Boolean  @default(true)
  valid_from                 DateTime?
  valid_until                DateTime?
  created_by                 String
  created_at                 DateTime @default(now())
  updated_at                 DateTime @updatedAt

  territory operational_territories @relation(fields: [territory_id], references: [id], onDelete: Cascade)

  @@index([territory_id])
  @@index([is_active])
}

// ─── Operadores Territoriais e Repasses ──────────────────────────────────────
model operator_profiles {
  id                              String    @id @default(uuid())
  admin_id                        String    @unique
  territory_id                    String
  recipient_type                  String    @default("individual") // "individual" | "company" | "association"
  relationship_type               String    @default("territorial_operator") // "territorial_operator" | "association_partner" | "consultant"
  display_name                    String
  email                           String?
  phone                           String?
  address                         String?
  pix_key                         String?
  pix_key_type                    String?   // "cpf" | "cnpj" | "email" | "phone" | "random"
  bank_name                       String?
  full_name                       String?   // PF
  document_cpf                    String?   // PF
  document_rg                     String?   // PF opcional
  company_name                    String?   // PJ/Associação
  trade_name                      String?   // PJ
  document_cnpj                   String?   // PJ/Associação
  legal_representative_name       String?   // PJ/Associação
  legal_representative_cpf        String?   // PJ/Associação
  document_status                 String    @default("pending") // "pending" | "verified" | "rejected"
  contract_status                 String    @default("pending") // "pending" | "signed" | "not_required"
  terms_accepted_at               DateTime?
  responsibility_terms_accepted_at DateTime?
  confidentiality_terms_accepted_at DateTime?
  terms_version                   String?   @db.VarChar(20)
  terms_accepted_by               String?
  contract_url                    String?
  contract_signed_at              DateTime?
  verified_by                     String?
  verified_at                     DateTime?
  rejected_reason                 String?
  notes                           String?
  is_active                       Boolean   @default(false)
  created_at                      DateTime  @default(now())
  updated_at                      DateTime  @updatedAt
  contract_template_url           String?
  contract_reviewed_by            String?
  contract_reviewed_at            DateTime? @db.Timestamptz
  contract_rejection_reason       String?

  admin     admins                  @relation(fields: [admin_id], references: [id], onDelete: Cascade)
  territory operational_territories @relation(fields: [territory_id], references: [id], onDelete: Cascade)
  payouts   territory_payouts[]
  contract_reviewer admins?         @relation("op_contract_reviewer", fields: [contract_reviewed_by], references: [id], onDelete: Restrict)
  submissions contract_submissions[]

  @@index([territory_id])
  @@index([is_active])
}

model contract_submissions {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  operator_profile_id   String
  submitted_by_admin_id String
  s3_key                String
  status                String   @default("submitted")
  reviewed_by           String?
  reviewed_at           DateTime? @db.Timestamptz
  rejection_reason      String?
  notes                 String?
  created_at            DateTime @default(now()) @db.Timestamptz
  updated_at            DateTime @default(now()) @db.Timestamptz

  // Trilha de auditoria — Fase 1
  signer_name           String?
  signer_email          String?
  signer_document       String?
  signer_ip             String?
  signer_user_agent     String?
  document_hash         String?
  contract_version      String?  @default("v1.0") @db.VarChar(20)
  submitted_at          DateTime? @db.Timestamptz

  operator  operator_profiles @relation(fields: [operator_profile_id], references: [id], onDelete: Restrict)
  submitter admins            @relation("cs_submitter", fields: [submitted_by_admin_id], references: [id], onDelete: Restrict)
  reviewer  admins?           @relation("cs_reviewer", fields: [reviewed_by], references: [id], onDelete: Restrict)

  @@index([operator_profile_id])
  @@index([status])
  @@index([created_at(sort: Desc)])
  @@index([document_hash])
}

model territory_payouts {
  id                  String    @id @default(uuid())
  territory_id        String
  operator_profile_id String
  reference_month     String
  calculated_amount   Decimal   @db.Decimal(10, 2)
  approved_amount     Decimal?  @db.Decimal(10, 2)
  status              String    @default("calculated") // "calculated" | "approved" | "paid" | "canceled"
  calculation_details Json?
  approved_by         String?
  approved_at         DateTime?
  paid_by             String?
  paid_at             DateTime?
  payment_method      String?
  payment_ref         String?
  receipt_url         String?
  fiscal_document_required Boolean @default(false)
  fiscal_document_type String  @default("none") // "none" | "receipt" | "nfse" | "invoice" | "other"
  fiscal_document_url String?
  fiscal_document_ref String?
  fiscal_notes        String?
  cancel_reason       String?
  notes               String?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  territory operational_territories @relation(fields: [territory_id], references: [id], onDelete: Cascade)
  operator  operator_profiles       @relation(fields: [operator_profile_id], references: [id], onDelete: Cascade)

  @@unique([territory_id, reference_month])
  @@index([status])
  @@index([operator_profile_id])
}

// ─── KAVIAR Pet ─────────────────────────────────────────────────────────────

