  @@index([member_id], map: "idx_manager_team_commissions_member")
}




// ─── Women Matching Consent Events ───────────────────────────────────────────
model women_matching_consent_events {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actor_type      String
  actor_id        String
  action          String
  consent_version String?
  source          String   @default("api")
  metadata        Json?    @db.JsonB
  created_at      DateTime @default(now()) @db.Timestamptz

  @@index([actor_type, actor_id, created_at(sort: Desc)])
  @@map("women_matching_consent_events")
}

// ─── Financial Shadow Mode (Phase 1) ────────────────────────────────────────

model platform_fee_configs {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  platform_fee_percent Decimal   @db.Decimal(5, 2)
  effective_from       DateTime  @db.Timestamptz
  effective_to         DateTime? @db.Timestamptz
  approval_status      String    @default("pending")
  change_reason        String
  created_by           String
  approved_by          String?
  approved_at          DateTime? @db.Timestamptz
  rejected_reason      String?
  created_at           DateTime  @default(now()) @db.Timestamptz

  creator              admins    @relation("fee_config_creator", fields: [created_by], references: [id], onDelete: Restrict)
  approver             admins?   @relation("fee_config_approver", fields: [approved_by], references: [id], onDelete: Restrict)
  shadow_results       wallet_shadow_results[]
}

model territory_manager_assignments {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  territory_id        String
  admin_id            String
  operator_profile_id String?
  status              String    @default("active")
  started_at          DateTime  @db.Timestamptz
  ended_at            DateTime? @db.Timestamptz
  end_reason          String?
  created_by          String
  created_at          DateTime  @default(now()) @db.Timestamptz
  updated_at          DateTime  @updatedAt @db.Timestamptz

  territory           operational_territories @relation(fields: [territory_id], references: [id], onDelete: Restrict)
  admin               admins                 @relation("tma_admin", fields: [admin_id], references: [id], onDelete: Restrict)
  creator             admins                 @relation("tma_creator", fields: [created_by], references: [id], onDelete: Restrict)
  shadow_results      wallet_shadow_results[]

  @@index([territory_id])
  @@index([admin_id])
}

model wallet_shadow_results {
  id                          BigInt    @id @default(autoincrement())
  ride_id                     String
  driver_id                   String
  calculation_version         Int       @default(1)
  calculation_status          String    @default("success")
  final_price_cents           Int?
  wait_charge_cents           Int?
  fee_config_id               String?   @db.Uuid
  fee_percent                 Decimal?  @db.Decimal(5, 2)
  fee_amount_cents            Int?
  matrix_share_percent        Decimal?  @db.Decimal(5, 2)
  matrix_share_cents          Int?
  manager_share_percent       Decimal?  @db.Decimal(5, 2)
  manager_share_cents         Int?
  driver_earnings_cents       Int?
  territory_id                String?
  assignment_id               String?   @db.Uuid
  assignment_status           String?
  allocation_reason           String?
  legacy_credit_cost          Int?
  legacy_nominal_value_cents  Int?
  divergence_cents            Int?
  reference_month             DateTime? @db.Date
  error_code                  String?
  error_message               String?
  created_at                  DateTime  @default(now()) @db.Timestamptz
  updated_at                  DateTime  @default(now()) @db.Timestamptz

  ride                        rides_v2                       @relation(fields: [ride_id], references: [id], onDelete: Restrict)
  driver                      drivers                        @relation(fields: [driver_id], references: [id], onDelete: Restrict)
  fee_config                  platform_fee_configs?          @relation(fields: [fee_config_id], references: [id], onDelete: Restrict)
  territory                   operational_territories?       @relation(fields: [territory_id], references: [id], onDelete: Restrict)
  assignment                  territory_manager_assignments? @relation(fields: [assignment_id], references: [id], onDelete: Restrict)

  @@unique([ride_id, calculation_version])
  @@index([reference_month])
  @@index([driver_id])
  @@index([calculation_status])
}

// ─── Wallet V2 ───────────────────────────────────────────────────────────────

model driver_wallets {
  driver_id      String   @id
  balance_cents  BigInt   @default(0)
  reserved_cents BigInt   @default(0)
  updated_at     DateTime @default(now()) @updatedAt
  driver         drivers  @relation(fields: [driver_id], references: [id])
}

model wallet_ledger {
  id                   BigInt   @id @default(autoincrement())
  driver_id            String
  entry_type           String
  balance_delta_cents  BigInt   @default(0)
  reserved_delta_cents BigInt   @default(0)
  balance_after_cents  BigInt
  reserved_after_cents BigInt
  reference_type       String?
  reference_id         String?
  actor_type           String?
  actor_id             String?
  reason               String
  metadata             Json?
  idempotency_key      String   @unique
  created_at           DateTime @default(now())
  driver               drivers  @relation(fields: [driver_id], references: [id])

  @@index([driver_id, created_at(sort: Desc)])
  @@index([reference_type, reference_id])
}

model wallet_recharges {
  id               String    @id @default(uuid()) @db.Uuid
  driver_id        String
  package_id       String?
  amount_cents     BigInt
  status           String    @default("pending")
  payment_provider String    @default("asaas")
  external_id      String?
  pix_qr_code      String?
  pix_copy_paste   String?
  pix_expires_at   DateTime?
  confirmed_at     DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @default(now()) @updatedAt
  driver           drivers   @relation(fields: [driver_id], references: [id])

  @@unique([payment_provider, external_id])
  @@index([driver_id, created_at(sort: Desc)])
}

model recharge_packages {
  id           String   @id
  label        String
  amount_cents BigInt
  sort_order   Int      @default(0)
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
}

model pending_debits {
  id                    BigInt    @id @default(autoincrement())
  ride_id               String    @unique
  driver_id             String
  final_price_cents     BigInt
  fee_percent_snapshot  Decimal   @default(18.00) @db.Decimal(5, 2)
  fee_amount_cents      BigInt
  fee_collected_cents   BigInt    @default(0)
  fee_pending_cents     BigInt
  reserved_amount_cents BigInt    @default(0)
  reason                String    @default("platform_fee")
  attempts              Int       @default(0)
  last_error            String?
  status                String    @default("pending")
  idempotency_key       String?   @unique
  created_at            DateTime  @default(now())
  resolved_at           DateTime?
  driver                drivers   @relation(fields: [driver_id], references: [id])
}

model ride_fee_splits {
  id                    BigInt   @id @default(autoincrement())
  ride_id               String   @unique
  driver_id             String
  final_price_cents     BigInt
  fee_percent           Decimal  @default(18.00) @db.Decimal(5, 2)
  fee_amount_cents      BigInt
  fee_collected_cents   BigInt   @default(0)
  fee_pending_cents     BigInt   @default(0)
  matrix_share_percent  Decimal  @default(60.00) @db.Decimal(5, 2)
  matrix_share_cents    BigInt
  manager_share_percent Decimal  @default(40.00) @db.Decimal(5, 2)
  manager_share_cents   BigInt
  territory_id          String?
  manager_id            String?
  reference_month       String
  collection_status     String   @default("collected")
  idempotency_key       String?  @unique
  created_at            DateTime @default(now())

  @@index([territory_id, reference_month])
}

model driver_referral_rewards {
  id                  BigInt    @id @default(autoincrement())
  driver_id           String    @unique
  referrer_id         String
  referrer_type       String
  first_valid_ride_id String
  total_reward_cents  BigInt    @default(2000)
  matrix_cost_cents   BigInt    @default(1000)
  manager_cost_cents  BigInt    @default(1000)
  territory_id        String?
  manager_id          String?
  status              String    @default("eligible")
  approved_at         DateTime?
  idempotency_key     String?   @unique
  created_at          DateTime  @default(now())
  driver              drivers   @relation(fields: [driver_id], references: [id])
  payouts             referral_reward_payouts[]
}

model referral_reward_payouts {
  id                 BigInt    @id @default(autoincrement())
  reward_id          BigInt
  referrer_type      String
  referrer_id        String
  amount_cents       BigInt    @default(2000)
  matrix_cost_cents  BigInt    @default(1000)
  manager_cost_cents BigInt    @default(1000)
  territory_id       String?
  manager_id         String?
  status             String    @default("pending")
  payment_method     String?
  paid_at            DateTime?
  idempotency_key    String?   @unique
  created_at         DateTime  @default(now())
  reward             driver_referral_rewards @relation(fields: [reward_id], references: [id])
}

model territory_ledger {
  id              BigInt   @id @default(autoincrement())
  territory_id    String
  manager_id      String?
  reference_month String
  entry_type      String
  amount_cents    BigInt
  description     String?
  reference_type  String?
  reference_id    String?
  idempotency_key String?  @unique
  created_at      DateTime @default(now())

  @@index([territory_id, reference_month])
  @@index([entry_type, reference_month])
}

// ─── Retorno Familiar KAVIAR (accrual, não saldo) ────────────────────────────

model family_return_accruals {
  id                   BigInt   @id @default(autoincrement())
  driver_id            String
  recharge_id          String   @db.Uuid
  source_amount_cents  BigInt
  accrued_amount_cents BigInt
  percent              Decimal  @default(10.00) @db.Decimal(5, 2)
  status               String   @default("accrued")
  idempotency_key      String   @unique
  created_at           DateTime @default(now())
  updated_at           DateTime @default(now()) @updatedAt

  @@index([driver_id, created_at(sort: Desc)])
  @@index([status])
}
