  preferred_windows Json      @default("{}")
  
  // Controle operacional
  pilot_start_date  DateTime?
  operational_notes String?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  
  driver            drivers   @relation("LocalSupportDriver", fields: [driver_id], references: [id], onDelete: Cascade)
  community         communities? @relation("LocalSupportCommunity", fields: [community_id], references: [id])
  invites           local_support_invites[]

  @@index([community_id])
  @@index([status])
}

model local_support_invites {
  id                      String    @id @default(uuid())
  driver_id               String
  community_id            String?
  
  // Dados do convite
  invited_at              DateTime  @default(now())
  region                  String?
  demand_type             String    @default("normal")
  
  // Resposta voluntária
  responded               Boolean   @default(false)
  response_time_minutes   Int?
  informed_availability   Boolean   @default(false)
  attended_ride           Boolean   @default(false)
  
  // Controle administrativo
  notes                   String?
  invited_by_admin_id     String?
  created_at              DateTime  @default(now())
  
  support_driver          local_support_drivers @relation(fields: [driver_id], references: [driver_id], onDelete: Cascade)
  community               communities? @relation("LocalSupportInviteCommunity", fields: [community_id], references: [id])

  @@index([driver_id, invited_at(sort: Desc)])
  @@index([community_id, invited_at(sort: Desc)])
}

// ─── Associações / Operadores Locais ───
model local_operators {
  id                    String    @id @default(uuid())
  organization_name     String
  responsible_name      String
  responsible_role      String    // presidente, liderança, vereador, representante
  phone                 String?
  email                 String?
  address               String?
  website               String?
  community             String?
  neighborhood          String?
  city                  String?
  source                String    @default("site")
  status                String    @default("researching")
  verified              Boolean   @default(false)
  notes                 String?
  next_followup_at      DateTime?
