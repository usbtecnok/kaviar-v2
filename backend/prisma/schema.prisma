// SPEC_RIDE_FLOW_V1 Models

enum RideStatus {
  scheduled
  requested
  offered
  pending_adjustment
  accepted
  arrived
  in_progress
  completed
  canceled_by_passenger
  canceled_by_driver
  no_driver
}

enum OfferStatus {
  pending
  accepted
  rejected
  expired
  canceled
}

enum DriverAvailability {
  offline
  online
  busy
}

model rides_v2 {
  id                     String       @id @default(uuid())
  passenger_id           String
  driver_id              String?
  status                 RideStatus   @default(requested)
  origin_lat             Decimal      @db.Decimal(10, 8)
  origin_lng             Decimal      @db.Decimal(11, 8)
  origin_text            String?
  origin_neighborhood_id String?
  origin_community_id    String?
  dest_lat               Decimal      @db.Decimal(10, 8)
  dest_lng               Decimal      @db.Decimal(11, 8)
  destination_text       String?
  dest_neighborhood_id   String?
  ride_type              String       @default("normal")
  service_category       String       @default("CAR_NORMAL")
  is_homebound           Boolean      @default(false)
  idempotency_key        String?
  trip_details           Json?
  scheduled_for          DateTime?
  // Pricing (cache operacional — fonte de verdade é ride_settlements)
  pricing_profile_id     String?      @db.Uuid
  quoted_price           Decimal?     @db.Decimal(8, 2)
  locked_price           Decimal?     @db.Decimal(8, 2)
  final_price            Decimal?     @db.Decimal(8, 2)
  platform_fee           Decimal?     @db.Decimal(8, 2)
  driver_earnings        Decimal?     @db.Decimal(8, 2)
  territory_match        String?
  // Driver adjustment (premium)
  driver_adjustment      Decimal?     @db.Decimal(8, 2)
  adjusted_price         Decimal?     @db.Decimal(8, 2)
  passenger_app_version  String?
  // Wait ("Levar e esperar")
  wait_requested         Boolean      @default(false)
  wait_estimated_min     Int?
  wait_started_at        DateTime?
  wait_ended_at          DateTime?
  // Women matching preference
  prefer_woman_driver    Boolean      @default(false)
  // Share
  share_token            String?      @unique
  share_expires_at       DateTime?
  // Timestamps
  requested_at           DateTime     @default(now())
  offered_at             DateTime?
  accepted_at            DateTime?
  boarding_code          String?
  arrived_at             DateTime?
  started_at             DateTime?
  completed_at           DateTime?
  canceled_at            DateTime?
  created_at             DateTime     @default(now())
  updated_at             DateTime     @updatedAt
  passenger              passengers   @relation("PassengerRidesV2", fields: [passenger_id], references: [id])
  driver                 drivers?     @relation("DriverRidesV2", fields: [driver_id], references: [id])
  origin_neighborhood    neighborhoods? @relation("RideOriginV2", fields: [origin_neighborhood_id], references: [id])
  dest_neighborhood      neighborhoods? @relation("RideDestV2", fields: [dest_neighborhood_id], references: [id])
  offers                 ride_offers[]
  settlement             ride_settlements?
  emergency_events       ride_emergency_events[]
  shadow_result          wallet_shadow_results[]

  @@map("rides_v2")
  @@index([status])
  @@index([passenger_id])
  @@index([driver_id])
  @@index([idempotency_key])
  @@index([created_at(sort: Desc)])
}

model ride_offers {
  id             String      @id @default(uuid())
  ride_id        String
  driver_id      String
  status         OfferStatus @default(pending)
  territory_tier String?
  sent_at        DateTime    @default(now())
  expires_at     DateTime
  responded_at   DateTime?
  rank_score         Decimal?    @db.Decimal(10, 2)
  driver_adjustment  Decimal?    @db.Decimal(8, 2)
  adjustment_status  String?     // null | pending | accepted | rejected | skipped
  created_at         DateTime    @default(now())
  updated_at     DateTime    @updatedAt
  ride           rides_v2    @relation(fields: [ride_id], references: [id], onDelete: Cascade)
  driver         drivers     @relation(fields: [driver_id], references: [id])

