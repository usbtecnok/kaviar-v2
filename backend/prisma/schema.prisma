// SPEC_RIDE_FLOW_V1 Models

enum RideStatus {
  scheduled
  requested
  offered
  pending_adjustment
  accepted
  arrived
  in_progress
  completed
  canceled_by_passenger
  canceled_by_driver
  no_driver
}

enum OfferStatus {
  pending
  accepted
  rejected
  expired
  canceled
}

enum DriverAvailability {
  offline
  online
  busy
}

model rides_v2 {
  id                     String       @id @default(uuid())
  passenger_id           String
  driver_id              String?
  status                 RideStatus   @default(requested)
  origin_lat             Decimal      @db.Decimal(10, 8)
  origin_lng             Decimal      @db.Decimal(11, 8)
  origin_text            String?
  origin_neighborhood_id String?
  origin_community_id    String?
  dest_lat               Decimal      @db.Decimal(10, 8)
  dest_lng               Decimal      @db.Decimal(11, 8)
  destination_text       String?
  dest_neighborhood_id   String?
  ride_type              String       @default("normal")
  is_homebound           Boolean      @default(false)
  idempotency_key        String?
  trip_details           Json?
  scheduled_for          DateTime?
  // Pricing (cache operacional — fonte de verdade é ride_settlements)
  pricing_profile_id     String?      @db.Uuid
  quoted_price           Decimal?     @db.Decimal(8, 2)
  locked_price           Decimal?     @db.Decimal(8, 2)
  final_price            Decimal?     @db.Decimal(8, 2)
  platform_fee           Decimal?     @db.Decimal(8, 2)
  driver_earnings        Decimal?     @db.Decimal(8, 2)
  territory_match        String?
  // Driver adjustment (premium)
  driver_adjustment      Decimal?     @db.Decimal(8, 2)
  adjusted_price         Decimal?     @db.Decimal(8, 2)
  passenger_app_version  String?
  // Wait ("Levar e esperar")
  wait_requested         Boolean      @default(false)
  wait_estimated_min     Int?
  wait_started_at        DateTime?
  wait_ended_at          DateTime?
  // Share
  share_token            String?      @unique
  share_expires_at       DateTime?
  // Timestamps
  requested_at           DateTime     @default(now())
  offered_at             DateTime?
  accepted_at            DateTime?
  arrived_at             DateTime?
  started_at             DateTime?
  completed_at           DateTime?
  canceled_at            DateTime?
  created_at             DateTime     @default(now())
  updated_at             DateTime     @updatedAt
  passenger              passengers   @relation("PassengerRidesV2", fields: [passenger_id], references: [id])
  driver                 drivers?     @relation("DriverRidesV2", fields: [driver_id], references: [id])
  origin_neighborhood    neighborhoods? @relation("RideOriginV2", fields: [origin_neighborhood_id], references: [id])
  dest_neighborhood      neighborhoods? @relation("RideDestV2", fields: [dest_neighborhood_id], references: [id])
  offers                 ride_offers[]
  settlement             ride_settlements?
  emergency_events       ride_emergency_events[]

  @@map("rides_v2")
  @@index([status])
  @@index([passenger_id])
  @@index([driver_id])
  @@index([idempotency_key])
  @@index([created_at(sort: Desc)])
}

model ride_offers {
  id             String      @id @default(uuid())
  ride_id        String
  driver_id      String
  status         OfferStatus @default(pending)
  territory_tier String?
  sent_at        DateTime    @default(now())
  expires_at     DateTime
  responded_at   DateTime?
  rank_score         Decimal?    @db.Decimal(10, 2)
  driver_adjustment  Decimal?    @db.Decimal(8, 2)
  adjustment_status  String?     // null | pending | accepted | rejected | skipped
  created_at         DateTime    @default(now())
  updated_at     DateTime    @updatedAt
  ride           rides_v2    @relation(fields: [ride_id], references: [id], onDelete: Cascade)
  driver         drivers     @relation(fields: [driver_id], references: [id])

  @@index([ride_id])
  @@index([driver_id])
  @@index([status])
  @@index([expires_at])
}

model driver_status {
  driver_id    String             @id
  availability DriverAvailability @default(offline)
  updated_at   DateTime           @updatedAt
  driver       drivers            @relation(fields: [driver_id], references: [id], onDelete: Cascade)
}

model consultant_leads {
  id                String          @id @default(uuid())
  name              String
  phone             String
  source            String          @default("whatsapp")
  status            String          @default("new") // new, contacted, converted, dismissed
  notes             String?
  assigned_to       String?
  assigned_at       DateTime?
  region            String?
  last_contact_at   DateTime?
  referral_agent_id String?
  referral_agent    referral_agents? @relation(fields: [referral_agent_id], references: [id])
  created_at        DateTime        @default(now())

  @@index([status])
  @@index([created_at(sort: Desc)])
  @@index([assigned_to])
  @@index([region])
}

model referral_agents {
  id                  String             @id @default(uuid())
  name                String
  phone               String             @unique
  email               String?
  pix_key             String?
  pix_key_type        String?
  referral_code       String?            @unique
  is_active           Boolean            @default(true)
  terms_accepted_at   DateTime?
  terms_accepted_ip   String?
  welcome_sent_at     DateTime?
  welcome_sent_status String?   // sent, skipped_disabled, skipped_no_template, failed
  created_at          DateTime           @default(now())
  updated_at          DateTime           @updatedAt
  referrals           referrals[]
  consultant_leads    consultant_leads[]
}

model referrals {
  id                    String    @id @default(uuid())
  agent_id              String
  driver_id             String?
  driver_phone          String    @unique
  lead_id               String?
  status                String    @default("pending")
  reward_amount         Decimal   @default(20.00) @db.Decimal(10, 2)
  qualified_at          DateTime?
  rejected_at           DateTime?
  rejection_reason      String?
  payment_status        String    @default("pending_pix")
  payment_approved_at   DateTime?
  payment_approved_by   String?
  payment_paid_at       DateTime?
  payment_paid_by       String?
  payment_ref           String?
  payment_canceled_at   DateTime?
  payment_cancel_reason String?
  source                String    @default("admin_manual")
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  agent                 referral_agents @relation(fields: [agent_id], references: [id])

  @@index([agent_id])
  @@index([status])
  @@index([payment_status])
  @@index([driver_id])
}

model driver_locations {
  driver_id  String   @id
  lat        Decimal  @db.Decimal(10, 8)
  lng        Decimal  @db.Decimal(11, 8)
  heading    Decimal? @db.Decimal(5, 2)
  speed      Decimal? @db.Decimal(5, 2)
  updated_at DateTime @updatedAt
  driver     drivers  @relation(fields: [driver_id], references: [id], onDelete: Cascade)

  @@index([updated_at(sort: Desc)])
}

// ─── Pricing ────────────────────────────────────────────────────────────────

model pricing_profiles {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug                 String   @unique
  name                 String

  // Fórmula base
  base_fare            Decimal  @db.Decimal(8, 2)
  per_km               Decimal  @db.Decimal(8, 2)
  per_minute           Decimal  @db.Decimal(8, 2)
  minimum_fare         Decimal  @db.Decimal(8, 2)

  // Taxa plataforma por camada territorial
  fee_local            Decimal  @default(7)  @db.Decimal(5, 2)
  fee_adjacent         Decimal  @default(12) @db.Decimal(5, 2)
  fee_external         Decimal  @default(20) @db.Decimal(5, 2)
  fee_homebound        Decimal? @db.Decimal(5, 2)

  // Custo de crédito por camada territorial
  credit_cost_local    Int      @default(1)
  credit_cost_external Int      @default(2)

  // Raio operacional
  max_dispatch_km      Decimal  @default(12) @db.Decimal(6, 2)

  // Geometria de cobertura
  center_lat           Decimal? @db.Decimal(10, 8)
  center_lng           Decimal? @db.Decimal(11, 8)
  radius_km            Decimal? @db.Decimal(8, 2)

  is_default           Boolean  @default(false)
  is_active            Boolean  @default(true)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  settlements          ride_settlements[]

  @@map("pricing_profiles")
}

model ride_settlements {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ride_id                 String   @unique

  // Perfil usado (snapshot)
  pricing_profile_id      String   @db.Uuid
  pricing_profile_slug    String

  // Território resolvido
  origin_neighborhood_id  String?
  origin_neighborhood     String?
  dest_neighborhood_id    String?
  dest_neighborhood       String?
  driver_neighborhood_id  String?
  driver_neighborhood     String?

  // Classificação territorial (sem ambiguidade)
  route_territory         String   // rota sem motorista
  driver_territory        String?  // com motorista (preenchido no refine)
  settlement_territory    String?  // usado para fee/crédito final (preenchido no settle)

  // Inputs
  distance_km             Decimal  @db.Decimal(8, 2)
  duration_min            Decimal? @db.Decimal(8, 2)

  // Parâmetros snapshot (imutável)
  base_fare_used          Decimal  @db.Decimal(8, 2)
  per_km_used             Decimal  @db.Decimal(8, 2)
  per_minute_used         Decimal  @db.Decimal(8, 2)
  minimum_fare_used       Decimal  @db.Decimal(8, 2)

  // Preços (ciclo de vida)
  quoted_price            Decimal  @db.Decimal(8, 2)
  locked_price            Decimal  @db.Decimal(8, 2)
  final_price             Decimal? @db.Decimal(8, 2)

  // Taxa e ganho
  fee_percent             Decimal  @db.Decimal(5, 2)
  fee_amount              Decimal  @db.Decimal(8, 2)
  driver_earnings         Decimal  @db.Decimal(8, 2)

  // Crédito
  credit_cost             Int?
  credit_match_type       String?

  // Timestamps
  quoted_at               DateTime
  locked_at               DateTime?
  refined_at              DateTime?
  settled_at              DateTime?

  created_at              DateTime @default(now())

  // Relations
  ride                    rides_v2         @relation(fields: [ride_id], references: [id])
  pricing_profile         pricing_profiles @relation(fields: [pricing_profile_id], references: [id])

  @@index([pricing_profile_id])
  @@index([settled_at])
  @@map("ride_settlements")
}

// ─── Central WhatsApp KAVIAR ───

model wa_conversations {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone               String    @unique @db.VarChar(20)

  // Identificação do contato
  contact_name        String?   @db.VarChar(255)
  whatsapp_name       String?   @db.VarChar(255)
  contact_type        String    @default("unknown") @db.VarChar(30)
  // driver | passenger | guide | consultant | lead | support | unknown

  // Vínculo com entidade do sistema
  linked_entity_type  String?   @db.VarChar(30)
  // driver | passenger | guide | consultant_lead | null
  linked_entity_id    String?   @db.VarChar(255)

  // Operação
  status              String    @default("new") @db.VarChar(20)
  // new | in_progress | awaiting_reply | resolved | spam
  priority            String    @default("normal") @db.VarChar(10)
  // normal | urgent
  assignee_id         String?   @db.Uuid

  // Contadores desnormalizados
  unread_count        Int       @default(0)
  message_count       Int       @default(0)
  last_message_at     DateTime?
  last_message_preview String?  @db.VarChar(200)
  last_inbound_at     DateTime?

  // Notas internas
  internal_notes      String?

  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  messages            wa_messages[]

  @@index([status])
  @@index([contact_type])
  @@index([last_message_at(sort: Desc)])
}

model wa_messages {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id     String    @db.Uuid

  direction           String    @db.VarChar(10)
  // inbound | outbound
  body                String

  // Twilio
  twilio_sid          String?   @db.VarChar(50)
  media_url           String?
  media_type          String?   @db.VarChar(50)

  // Outbound
  sent_by_admin_id    String?   @db.Uuid
  sent_by_admin_name  String?   @db.VarChar(255)

  // Delivery
  delivery_status     String?   @default("sent") @db.VarChar(20)

  created_at          DateTime  @default(now())

  conversation        wa_conversations @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@index([conversation_id, created_at])
}

// ─── Emergency Vault (Cofre de Evidência V1) ────────────────────────────────

model ride_emergency_events {
  id                String   @id @default(uuid())
  ride_id           String
  triggered_by_type String   // 'passenger' | 'driver'
  triggered_by_id   String
  trigger_source    String   @default("emergency_button")
  status            String   @default("active") // 'active' | 'resolved' | 'false_alarm'

  snapshot          Json     // Frozen ride context at trigger time

  resolved_by       String?
  resolved_at       DateTime?
  resolution_notes  String?

  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  ride              rides_v2                  @relation(fields: [ride_id], references: [id])
  location_trail    emergency_location_trail[]

  @@index([ride_id])
  @@index([status])
  @@index([created_at(sort: Desc)])
}

model emergency_location_trail {
  id                 String   @id @default(uuid())
  emergency_event_id String
  source             String   // 'driver' | 'passenger'
  lat                Decimal  @db.Decimal(10, 8)
  lng                Decimal  @db.Decimal(11, 8)
  speed              Decimal? @db.Decimal(5, 2)
  heading            Decimal? @db.Decimal(5, 2)
  captured_at        DateTime

  event              ride_emergency_events @relation(fields: [emergency_event_id], references: [id], onDelete: Cascade)

  @@unique([emergency_event_id, captured_at])
  @@index([emergency_event_id, captured_at])
}

