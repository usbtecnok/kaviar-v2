// ─── CRM Comercial KAVIAR (Fase 1) ──────────────────────────────────────────

model crm_leads {
  id                        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                      String    @db.VarChar(255)
  business_name             String?   @db.VarChar(255)
  phone                     String?   @db.VarChar(30)
  email                     String?   @db.VarChar(255)
  lead_type                 String    @default("OTHER") @db.VarChar(50)
  status                    String    @default("NEW") @db.VarChar(30)
  source                    String    @default("MANUAL") @db.VarChar(50)

  // Comércio local
  business_category         String?   @db.VarChar(50)
  business_address          String?
  contact_person            String?   @db.VarChar(255)
  wants_showcase            Boolean?
  wants_delivery_support    Boolean?
  wants_partnership         Boolean?
  wants_ads                 Boolean?
  commercial_notes          String?

  // Vínculos opcionais
  territory_id              String?   @db.Uuid
  neighborhood_id           String?
  assigned_admin_id         String?
  related_driver_id         String?
  related_passenger_id      String?
  related_partner_id        String?   @db.Uuid
  related_private_ride_id   String?   @db.Uuid
  related_pet_homologation_id String? @db.Uuid
  related_showcase_item_id  String?   @db.Uuid

  // Acompanhamento
  priority                  String    @default("NORMAL") @db.VarChar(10)
  notes                     String?
  next_action               String?   @db.VarChar(500)
  next_action_at            DateTime?
  last_contact_at           DateTime?
  created_by_admin_id       String?
  created_at                DateTime  @default(now())
  updated_at                DateTime  @updatedAt
  deleted_at                DateTime?

  // Captação
  captured_by_member_id     String?   @db.Uuid
  captured_by_member        manager_team_members? @relation(fields: [captured_by_member_id], references: [id], onDelete: SetNull)

  interactions              crm_interactions[]

  @@index([status], map: "idx_crm_leads_status")
  @@index([lead_type], map: "idx_crm_leads_lead_type")
  @@index([territory_id], map: "idx_crm_leads_territory")
  @@index([assigned_admin_id], map: "idx_crm_leads_assigned")
  @@index([next_action_at], map: "idx_crm_leads_next_action")
  @@index([priority], map: "idx_crm_leads_priority")
  @@index([captured_by_member_id], map: "idx_crm_leads_captured_by")
}

model crm_interactions {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lead_id             String   @db.Uuid
  event_type          String   @db.VarChar(50)
  description         String?
  old_status          String?  @db.VarChar(30)
  new_status          String?  @db.VarChar(30)
  created_by_admin_id String?
  created_at          DateTime @default(now())

  lead                crm_leads @relation(fields: [lead_id], references: [id], onDelete: Cascade)

  @@index([lead_id, created_at(sort: Desc)], map: "idx_crm_interactions_lead")
  @@index([created_by_admin_id], map: "idx_crm_interactions_admin")
}

// ─── KAVIAR Comércio Local (Fase 1) ─────────────────────────────────────────

model commerce_accounts {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  crm_lead_id         String?   @db.Uuid
  slug                String?   @unique @db.VarChar(100)
  name                String    @db.VarChar(255)
  trade_name          String?   @db.VarChar(255)
  category            String    @default("outro") @db.VarChar(50)
  document_cnpj       String?   @db.VarChar(20)
  document_cpf        String?   @db.VarChar(14)
  phone               String?   @db.VarChar(30)
  email               String?   @db.VarChar(255)
  address             String?
  neighborhood_id     String?
  territory_id        String?   @db.Uuid
  logo_url            String?
  is_active           Boolean   @default(false)
  status              String    @default("pending") @db.VarChar(30)
  commission_percent  Decimal   @default(10.00) @db.Decimal(5, 2)
  approved_by         String?
  approved_at         DateTime?
  notes               String?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  deleted_at          DateTime?

  users               commerce_users[]
  products            commerce_products[]
  orders              commerce_orders[]
  wallet              commerce_wallets?

  // Payout info (dados para KAVIAR pagar o comércio)
  payout_pix_key_type String?   @db.VarChar(20)
  payout_pix_key      String?   @db.VarChar(100)
  payout_receiver_name String?  @db.VarChar(255)

  @@index([status], map: "idx_commerce_accounts_status")
  @@index([territory_id], map: "idx_commerce_accounts_territory")
  @@index([crm_lead_id], map: "idx_commerce_accounts_crm_lead")
}

model commerce_users {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commerce_account_id   String    @db.Uuid
  name                  String    @db.VarChar(255)
  email                 String    @unique @db.VarChar(255)
  password_hash         String    @db.VarChar(255)
  role                  String    @default("owner") @db.VarChar(20)
  is_active             Boolean   @default(true)
  must_change_password  Boolean   @default(true)
  last_login_at         DateTime?
  created_at            DateTime  @default(now())

  account               commerce_accounts @relation(fields: [commerce_account_id], references: [id], onDelete: Cascade)

  @@index([commerce_account_id], map: "idx_commerce_users_account")
}

model commerce_products {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commerce_account_id String    @db.Uuid
  name                String    @db.VarChar(255)
  description         String?
  category            String?   @db.VarChar(50)
  price_cents         Int
  image_url           String?
  is_available        Boolean   @default(true)
  is_restricted       Boolean   @default(false)
  stock_quantity      Int?
  min_stock_alert     Int?
  sort_order          Int       @default(0)
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  deleted_at          DateTime?

  account             commerce_accounts @relation(fields: [commerce_account_id], references: [id], onDelete: Cascade)

  @@index([commerce_account_id], map: "idx_commerce_products_account")
  @@index([commerce_account_id, is_available], map: "idx_commerce_products_available")
}

model commerce_orders {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commerce_account_id     String    @db.Uuid
  customer_name           String    @db.VarChar(255)
  customer_phone          String    @db.VarChar(30)
  customer_address        String?
  delivery_type           String    @default("pickup") @db.VarChar(20)
  status                  String    @default("PENDING") @db.VarChar(30)
  subtotal_cents          Int
  delivery_fee_cents      Int       @default(0)
  kaviar_commission_cents Int
  commerce_net_cents      Int
  total_cents             Int
  payment_method          String?   @db.VarChar(20)
  payment_status          String    @default("pending") @db.VarChar(20)
  asaas_payment_id        String?
  pix_qr_code             String?
  pix_copy_paste          String?
  pix_expires_at          DateTime?
  paid_at                 DateTime?
  order_code              String?   @unique @db.VarChar(10)
  delivery_code           String?   @db.VarChar(6)
  delivery_status         String    @default("none") @db.VarChar(20)
  delivery_requested_at   DateTime?
  driver_id               String?
  driver_name             String?   @db.VarChar(100)
  dispatched_at           DateTime?
  delivered_at            DateTime?
  notes                   String?
  accepted_at             DateTime?
  prepared_at             DateTime?
  ready_at                DateTime?
  canceled_at             DateTime?
  cancel_reason           String?
  completed_at            DateTime?
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt

  account                 commerce_accounts @relation(fields: [commerce_account_id], references: [id])
  items                   commerce_order_items[]

  @@index([commerce_account_id, status], map: "idx_commerce_orders_account_status")
  @@index([status], map: "idx_commerce_orders_status")
  @@index([created_at(sort: Desc)], map: "idx_commerce_orders_created")
}

model commerce_order_items {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id        String   @db.Uuid
  product_id      String   @db.Uuid
  product_name    String   @db.VarChar(255)
  quantity        Int
  unit_price_cents Int
  total_cents     Int
  notes           String?  @db.VarChar(255)

  order           commerce_orders @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([order_id], map: "idx_commerce_order_items_order")
}

model commerce_wallets {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commerce_account_id     String   @unique @db.Uuid
  available_balance_cents Int      @default(0)
  pending_balance_cents   Int      @default(0)
  total_received_cents    Int      @default(0)
  total_withdrawn_cents   Int      @default(0)
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  account                 commerce_accounts @relation(fields: [commerce_account_id], references: [id])
}

model commerce_wallet_transactions {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commerce_account_id String   @db.Uuid
  order_id            String?  @db.Uuid
  withdrawal_id       String?  @db.Uuid
  type                String   @db.VarChar(30)
  amount_cents        Int
  balance_after_cents Int
  description         String?  @db.VarChar(500)
  created_by_admin_id String?
  created_at          DateTime @default(now())

  @@index([commerce_account_id, created_at(sort: Desc)], map: "idx_commerce_wallet_tx_account")
}

model commerce_withdrawal_requests {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commerce_account_id String    @db.Uuid
  amount_cents        Int
  status              String    @default("REQUESTED") @db.VarChar(20)
  pix_key_type        String?   @db.VarChar(20)
  pix_key             String?   @db.VarChar(100)
  receiver_name       String?   @db.VarChar(255)
  requested_at        DateTime  @default(now())
  approved_by_admin_id String?
  approved_at         DateTime?
  paid_by_admin_id    String?
  paid_at             DateTime?
  rejection_reason    String?
  notes               String?
  created_at          DateTime  @default(now())

  @@index([commerce_account_id, status], map: "idx_commerce_withdrawals_account")
  @@index([status], map: "idx_commerce_withdrawals_status")
}

// ─── Equipe do Gestor Territorial ───────────────────────────────────────────

model manager_team_members {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  manager_admin_id  String
  territory_id      String?
  name              String    @db.VarChar(255)
  phone             String?   @db.VarChar(30)
  role_type         String    @default("outro") @db.VarChar(30)
  status            String    @default("active") @db.VarChar(20)
  notes             String?
  cpf               String?   @db.VarChar(14)
  address           String?
  city              String?   @db.VarChar(100)
  state             String?   @db.VarChar(2)
  zipcode           String?   @db.VarChar(10)
  pix_key           String?   @db.VarChar(100)
  pix_key_type      String?   @db.VarChar(20)
  contract_status   String    @default("pending") @db.VarChar(20)
  contract_signed_at DateTime?
